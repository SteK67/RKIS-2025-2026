<Window x:Class="TodoApp.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TodoApp.Desktop.ViewModels"
        xmlns:models="clr-namespace:TodoApp.Models;assembly=TodoApp.Models"
        Title="TodoApp Desktop" Height="720" Width="1040" MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen" Background="#F4EFE7">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="BorderBrush" Value="#D7C8B6" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,6,0,12" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#243B36" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#C66A43" />
        </Style>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <Border Width="420" Padding="34" Background="#FFFDF8" CornerRadius="22">
                <StackPanel>
                    <TextBlock Text="Вход в профиль" FontSize="30" FontWeight="Bold" Foreground="#243B36" Margin="0,0,0,20" />
                    <TextBlock Text="Логин" />
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Пароль" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Войти" Command="{Binding LoginCommand}" />
                        <Button Content="Регистрация" Style="{StaticResource SecondaryButton}" Command="{Binding ShowRegisterCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <Border Width="480" Padding="34" Background="#FFFDF8" CornerRadius="22">
                <StackPanel>
                    <TextBlock Text="Регистрация" FontSize="30" FontWeight="Bold" Foreground="#243B36" Margin="0,0,0,20" />
                    <TextBlock Text="Логин" />
                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Пароль" />
                    <TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Имя" />
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Фамилия" />
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Text="Год рождения" />
                    <TextBox Text="{Binding BirthYear, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Создать профиль" Command="{Binding RegisterCommand}" />
                        <Button Content="Назад" Style="{StaticResource SecondaryButton}" Command="{Binding ShowLoginCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TodoListViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Padding="22" Background="#FFFDF8" CornerRadius="22" Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,18,0">
                            <TextBlock Text="Поиск по тексту" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,18,0">
                            <TextBlock Text="Фильтр статуса" />
                            <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" />
                        </StackPanel>
                        <Button Grid.Column="2" Content="Добавить задачу" Command="{Binding AddCommand}" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Border Grid.Row="1" Padding="20" Background="#FFFDF8" CornerRadius="22">
                    <DataGrid ItemsSource="{Binding FilteredTodos}" SelectedItem="{Binding SelectedTodo}" AutoGenerateColumns="False"
                              CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowHeight="44" FontSize="14">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70" />
                            <DataGridTextColumn Header="Текст" Binding="{Binding Text}" Width="*" />
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="150" />
                            <DataGridTextColumn Header="Дата" Binding="{Binding LastUpdate, StringFormat=dd.MM.yyyy HH:mm}" Width="170" />
                            <DataGridTemplateColumn Header="Действия" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Изменить" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                            <Button Content="Удалить" Style="{StaticResource SecondaryButton}" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AddTaskViewModel}">
            <Border Width="560" Padding="34" Background="#FFFDF8" CornerRadius="22">
                <StackPanel>
                    <TextBlock Text="Новая задача" FontSize="30" FontWeight="Bold" Foreground="#243B36" Margin="0,0,0,20" />
                    <TextBlock Text="Текст задачи" />
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Height="140" AcceptsReturn="True" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" />
                        <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EditTaskViewModel}">
            <Border Width="560" Padding="34" Background="#FFFDF8" CornerRadius="22">
                <StackPanel>
                    <TextBlock Text="Редактирование задачи" FontSize="30" FontWeight="Bold" Foreground="#243B36" Margin="0,0,0,20" />
                    <TextBlock Text="Текст задачи" />
                    <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Height="140" AcceptsReturn="True" TextWrapping="Wrap" />
                    <TextBlock Text="Статус" />
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" />
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Сохранить" Command="{Binding SaveCommand}" />
                        <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Text="TodoApp Desktop" FontSize="38" FontWeight="Black" Foreground="#243B36" />
        <TextBlock Grid.Row="1" Text="{Binding Message}" Foreground="#B6462D" FontSize="16" FontWeight="SemiBold" Margin="0,10,0,18" />
        <ContentControl Grid.Row="2" Content="{Binding CurrentViewModel}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Grid>
</Window>
